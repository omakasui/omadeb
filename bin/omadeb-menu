  *Signal*) install_app "Signal" "signal" ;;
  *Spotify*) install_app "Spotify" "spotify" ;;
  *Typora*) install_app "Typora" "typora" ;;
  *Tailscale*) install_app "Tailscale" "tailscale" ;;
  *Zoom*) install_app "Zoom" "zoom" ;;
  *) show_install_menu ;;
  esac
}

