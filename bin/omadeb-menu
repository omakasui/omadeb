show_update_menu() {
  local brand_name=$(omadeb-brand)

  case $(menu "Update" "¾░¤ó  $brand_name\n¾░ö½  Channel\nŅśĢ  Config\n¾░Ėī  Themes\n¾░ćģ  Hardware\nŅ®Ė  Firmware\nŅ¼æ  Password" "--width 250 --height 320") in
  *$brand_name*) present_terminal omadeb-update ;;
  *Channel*) show_update_channel_menu ;;
  *Config*) show_update_config_menu ;;
  *Themes*) present_terminal omadeb-theme-update ;;
  *Hardware*) show_update_hardware_menu ;;
  *Firmware*) present_terminal omadeb-update-firmware ;;
  *Password*) show_update_password_menu ;;
  *) show_main_menu ;;
  esac
}

