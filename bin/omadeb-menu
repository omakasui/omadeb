show_update_menu() {
  local brand_name=$(omadeb-brand)

  case $(menu "Update" "¾░¤ó  $brand_name\n¾░ö½  Channel\nŅśĢ  Config\n¾░Ėī  Themes\nŅ«ó  Process\n¾░ćģ  Hardware\nŅ®Ė  Firmware\nŅ¼æ  Password") in
  *$brand_name*) present_terminal omadeb-update ;;
  *Channel*) show_update_channel_menu ;;
  *Config*) show_update_config_menu ;;
  *Themes*) present_terminal omadeb-theme-update ;;
  *Process*) show_update_process_menu ;;
  *Hardware*) show_update_hardware_menu ;;
  *Firmware*) present_terminal omadeb-update-firmware ;;
  *Password*) show_update_password_menu ;;
  *) show_main_menu ;;
  esac
}

show_update_channel_menu() {
  case $(menu "Update channel" "­¤¤ó Stable\n­¤ö┤ Dev") in
  *Stable*) present_terminal "omadeb-channel-set stable" ;;
  *Dev*) present_terminal "omadeb-channel-set dev" ;;
  *) show_update_menu ;;
  esac
}

show_update_config_menu() {
  case $(menu "Use default config" "’ŹĪ  Gnome\n¾░Źé  GDM\n’ä£  Keybindings\n¾▒Ż┤  Plymouth\n¾░ī¦  Walker\n’äĄ  Starship\nŅ»ł  Zellij") in
  *Gnome*) present_terminal omadeb-refresh-gnome ;;
  *GDM*) present_terminal omadeb-refresh-gdm ;;
  *Keybindings*) present_terminal omadeb-refresh-keybindings ;;
  *Plymouth*) present_terminal omadeb-refresh-plymouth ;;
