#!/bin/bash

# Set GNOME theme according to Omadeb current theme.

# Change gnome modes
GTK_THEME=~/.config/omadeb/current/theme/gtk.theme
GTK_LIGHT_MODE=~/.config/omadeb/current/theme/light.mode

if [[ -f $GTK_THEME ]]; then
  GNOME_GTK_THEME=$(<$GTK_THEME)
else
  GNOME_GTK_THEME="Yaru-blue"
fi

if [[ -f $GTK_LIGHT_MODE ]]; then
  gsettings set org.gnome.desktop.interface color-scheme "prefer-light"
  gsettings set org.gnome.desktop.interface gtk-theme "$GNOME_GTK_THEME"
else
  gsettings set org.gnome.desktop.interface color-scheme "prefer-dark"
  if [[ -d "/usr/share/themes/${GNOME_GTK_THEME}-dark" ]]; then
    gsettings set org.gnome.desktop.interface gtk-theme "${GNOME_GTK_THEME}-dark"
  else
    gsettings set org.gnome.desktop.interface gtk-theme "$GNOME_GTK_THEME"
  fi
fi

# Change gnome shell theme
GNOME_SHELL_THEME=~/.config/omadeb/current/theme/shell.theme
if [[ -f $GNOME_SHELL_THEME ]]; then
  gsettings set org.gnome.shell.extensions.user-theme name "$(<$GNOME_SHELL_THEME)"
else
  if [[ $GNOME_GTK_THEME == *"yaru"* ]]; then
    if [[ -f $GTK_LIGHT_MODE ]]; then
      gsettings set org.gnome.shell.extensions.user-theme name "Yaru"
    else
      gsettings set org.gnome.shell.extensions.user-theme name "Yaru-dark"
    fi
  else
    gsettings set org.gnome.shell.extensions.user-theme name "Default"
  fi
fi

# Change gnome accent color
GNOME_ACCENT_THEME=~/.config/omadeb/current/theme/accent.theme
if [[ -f $GNOME_ACCENT_THEME ]]; then
  gsettings set org.gnome.desktop.interface accent-color "$(<$GNOME_ACCENT_THEME)" 2>/dev/null || true
else
  gsettings set org.gnome.desktop.interface accent-color "orange" 2>/dev/null || true
fi

# Change gnome cursor theme color
GNOME_CURSOR_THEME=~/.config/omadeb/current/theme/cursor.theme
if [[ -f $GNOME_CURSOR_THEME ]]; then
  gsettings set org.gnome.desktop.interface cursor-theme "$(<$GNOME_CURSOR_THEME)"
else
  gsettings set org.gnome.desktop.interface cursor-theme "Yaru"
fi

# Change gnome icon theme color
GNOME_ICONS_THEME=~/.config/omadeb/current/theme/icons.theme
if [[ -f $GNOME_ICONS_THEME ]]; then
  gsettings set org.gnome.desktop.interface icon-theme "$(<$GNOME_ICONS_THEME)"
else
  gsettings set org.gnome.desktop.interface icon-theme "${GNOME_GTK_THEME}"
fi

# Change gnome extensions theme
GNOME_TOPHAT_THEME=~/.config/omadeb/current/theme/tophat.theme
if [[ -f $GNOME_TOPHAT_THEME ]]; then
  gsettings set org.gnome.shell.extensions.tophat meter-fg-color "$(<$GNOME_TOPHAT_THEME)"
else
  if [[ -f ~/.config/omadeb/current/theme/light.mode ]]; then
    gsettings set org.gnome.shell.extensions.tophat meter-fg-color "#e92020"
  else
    gsettings set org.gnome.shell.extensions.tophat meter-fg-color "#33ccff"
  fi
fi
