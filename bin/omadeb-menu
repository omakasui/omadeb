  case $(menu "Use default config" "’ŹĪ  Gnome\n¾░Źé  GDM\n’ä£  Keybindings\n¾▒Ż┤  Plymouth\n¾░ī¦  Wofi\n’äĄ  Starship\nŅ»ł  Zellij" "--width 250 --height 320") in
