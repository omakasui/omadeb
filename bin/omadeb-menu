  case $(menu "Restart" "¾░ī¦  Walker") in
  *Walker*) omadeb-restart-walker ;;
  *) show_update_menu ;;
  esac
}

show_update_hardware_menu() {
  case $(menu "Restart" "ŅśĖ  Audio") in
  *Audio*) present_terminal omadeb-restart-pipewire ;;
  *) show_update_menu ;;
  esac
}

show_update_password_menu() {
  case $(menu "Update Password" "Ņ¼æ  User") in
  *User*) present_terminal passwd ;;
  *) show_update_menu ;;
  esac
}

show_about() {
  omadeb-launch-about
}

show_system_menu() {
  local options="¾░īŠ  Lock"
  [[ ! -f ~/.local/state/omadeb/toggles/suspend-off ]] && options="$options\n¾░Æ▓  Suspend"
  options="$options\n¾░īŠ  Logout\n¾░£ē  Restart\n¾░Éź  Shutdown"

  case $(menu "System" "$options") in
  *Lock*) omadeb-system-lock-screen ;;
  *Suspend*) systemctl suspend ;;
  *Logout*) omadeb-system-logout ;;
  *Restart*) omadeb-system-reboot ;;
  *Shutdown*) omadeb-system-shutdown ;;
  *) back_to show_main_menu ;;
  esac
}

show_main_menu() {
  go_to_menu "$(menu "Go" "¾░Ć╗  Apps\n¾░¦æ  Learn\n¾▒ō×  Trigger\nŅ»Å  Style\nŅśĢ  Setup\n¾░ēē  Install\n¾░Łī  Remove\n¾░æÉ  Update\nŅ®┤  About\n¾░żå  System")"
}

go_to_menu() {
  case "${1,,}" in
  *apps*) omadeb-apps ;;
  *learn*) show_learn_menu ;;
  *trigger*) show_trigger_menu ;;
  *toggle*) show_toggle_menu ;;
  *style*) show_style_menu ;;
  *background*) show_background_menu ;;
  *theme*) show_theme_menu ;;
  *setup*) show_setup_menu ;;
  *install*) show_install_menu ;;
  *remove*) show_remove_menu ;;
  *update*) show_update_menu ;;
  *about*) show_about ;;
  *system*) show_system_menu ;;
  esac
}

# Allow user extensions and overrides
USER_EXTENSIONS="$HOME/.config/omadeb/extensions/menu.sh"
[[ -f $USER_EXTENSIONS ]] && source "$USER_EXTENSIONS"

toggle_existing_menu

if [[ -n "$1" ]]; then
  BACK_TO_EXIT=true
  go_to_menu "$1"
else
  show_main_menu
fi