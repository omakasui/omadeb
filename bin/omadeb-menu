#!/bin/bash

# Launch the Omadeb Menu or takes a parameter to jump straight to a submenu.

export PATH="$HOME/.local/share/omadeb/bin:$PATH"

# Set to true when going directly to a submenu, so we can exit directly
BACK_TO_EXIT=false

back_to() {
  local parent_menu="$1"

  if [[ $BACK_TO_EXIT == "true" ]]; then
    exit 0
  elif [[ -n $parent_menu ]]; then
    "$parent_menu"
  else
    show_main_menu
  fi
}

toggle_existing_menu() {
  if pgrep -f "walker.*--dmenu" >/dev/null; then
    walker --close >/dev/null 2>&1
    exit 0
  fi
    # Close any existing instance of walker to preserve menu dimensions
  pkill -x walker >/dev/null 2>&1
}

menu() {
  local prompt="$1"
  local options="$2"
  local extra="$3"
  local preselect="$4"

  read -r -a args <<<"$extra"

  if [[ -n $preselect ]]; then
    local index
    index=$(echo -e "$options" | grep -nxF "$preselect" | cut -d: -f1)
    if [[ -n $index ]]; then
      args+=("-c" "$index")
    fi
  fi

  echo -e "$options" | omadeb-launch-walker --dmenu --width 295 --minheight 1 --maxheight 630 -p "$prompt‚Ä¶" "${args[@]}" 2>/dev/null
}

terminal() {
  xdg-terminal-exec "$@"
}

present_terminal() {
  omadeb-launch-terminal-with-presentation "$@"
}

open_in_editor() {
  omadeb-notify -u low "Editing config file" "$1"
  omadeb-launch-editor "$1"
}

install() {
  present_terminal "echo 'Installing $1...'; omadeb-pkg-add $2"
}

install_app() {
  present_terminal "echo 'Installing $1...'; omadeb-app-install $2"
}

install_font() {
  present_terminal "echo 'Installing $1...'; omadeb-install-font $2 && sleep 2 && omadeb-font-set '$3'"
}

install_terminal() {
  present_terminal "omadeb-install-terminal $1"
}

remove() {
  present_terminal "echo 'Removing $1...'; omadeb-pkg-drop $2"
}

remove_app() {
  present_terminal "echo 'Removing $1...'; omadeb-app-remove $2"
}

remove_font() {
  present_terminal "echo 'Removing $1...'; omadeb-remove-font $2"
}

show_learn_menu() {
  case $(menu "Learn" "ÔĄú  Keybindings\nÔźÖ  Omadeb\nÔĆÜ  Debian\nůįä¨  GNOME\nÓöģ  Neovim\nůĪÜÉ  Bash") in
  *Keybindings*) omadeb-launch-webapp "https://omadeb.omakasui.org/manual/essentials/hotkeys" "Omadeb Keybindings" ;;
  *Omadeb*) omadeb-launch-webapp "https://omadeb.omakasui.org/manual" "Omadeb" ;;
  *Debian*) omadeb-launch-webapp "https://www.debian.org/doc/" "Debian" ;;
  *GNOME*) omadeb-launch-webapp "https://help.gnome.org/" "GNOME" ;;
  *Bash*) omadeb-launch-webapp "https://devhints.io/bash" "Bash" ;;
  *Neovim*) omadeb-launch-webapp "https://www.lazyvim.org/keymaps" "Neovim" ;;
  *) show_main_menu ;;
  esac
}

show_trigger_menu() {
  case $(menu "Trigger" "ÔĒé  Share\nůįĒé  Toggle") in
  *Share*) show_share_menu ;;
  *Toggle*) show_toggle_menu ;;
  *) show_main_menu ;;
  esac
}

show_share_menu() {
  case $(menu "Share" "ÔĀŅ  Clipboard\nÓ©Ľ  File \nÔĄĒ  Folder") in
  *Clipboard*) omadeb-cmd-share clipboard ;;
  *File*) terminal bash -c "omadeb-cmd-share file" ;;
  *Folder*) terminal bash -c "omadeb-cmd-share folder" ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_toggle_menu() {
  case $(menu "Toggle" "ůįĒé  Nightlight") in
  *Nightlight*) omadeb-toggle-nightlight ;;
  *) back_to show_trigger_menu ;;
  esac
}


show_style_menu() {
  case $(menu "Style" "ůįłĆ  Theme\nÓôô  Font\nÔÄĺ  Background") in
  *Theme*) show_theme_menu ;;
  *Font*) show_font_menu ;;
  *Background*) show_background_menu ;;
  *) show_main_menu ;;
  esac
}

show_theme_menu() {
  omadeb-launch-walker -m menus:omadebthemes --width 800 --minheight 400
}

show_font_menu() {
  case $(menu "Font" "Óôô  Family\nůįßī  Size") in
  *Family*) show_font_family_menu ;;
  *Size*) present_terminal omadeb-font-size-set ;;
  *) show_main_menu ;;
  esac
}

show_font_family_menu() {
  font=$(menu "Font" "$(omadeb-font-list)" "--width 350" "$(omadeb-font-current)")
  if [[ $font == "CNCLD" || -z $font ]]; then
    back_to show_style_menu
  else
    omadeb-font-set "$font"
  fi
}

show_background_menu() {
  omadeb-launch-walker -m menus:omadebBackgroundSelector --width 800 --minheight 400
}

show_setup_menu() {
  case $(menu "Setup" "ůį§Ü  System Sleep\nÓ™É  Folders\nÔĄú  Keybindings\nÔĄĶ  Starship\nůįĆß  Walker\nůįěÖ  XCompose") in
  *System*) show_setup_system_menu ;;
  *Folders*) show_setup_folders_menu ;;
  *Keybindings*) show_setup_keybindings_menu ;;
  *Starship*) edit_in_nvim ~/.config/starship.toml ;;
  *Walker*) open_in_editor ~/.config/walker/config.toml && omadeb-restart-walker ;;
  *XCompose*) open_in_editor ~/.XCompose && omadeb-restart-xcompose ;;
  *) show_main_menu ;;
  esac
}

show_setup_system_menu() {
  local options=""

 if [[ -f ~/.local/state/omadeb/toggles/suspend-off ]]; then
    options="$optionsůįí≤  Enable Suspend"
  else
    options="$optionsůįí≤  Disable Suspend"
  fi

  case $(menu "System" "$options") in
  *Suspend*) omadeb-toggle-suspend ;;
  *) show_setup_menu ;;
  esac
}

show_setup_folders_menu() {
  case $(menu "Folders" "ůįģĚ  Add\nůįģě  Remove") in
  *Add*) present_terminal omadeb-app-folder-add ;;
  *Remove*) present_terminal omadeb-app-folder-remove ;;
  *) show_setup_menu ;;
  esac
}

