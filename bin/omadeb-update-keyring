#!/bin/bash

# Before updating the system, we need to make sure the Omakasui APT repository keyrings are up to date.

codename=$(. /etc/os-release && echo "${UBUNTU_CODENAME:-$VERSION_CODENAME}")
channel=$(omadeb-version-channel)
if [[ $channel == "dev" ]]; then
  suite="${codename}-dev"
else
  suite="$codename"
fi

_ensure_keyring() {
  local keyring_url="$1"
  local keyring_path="$2"
  local sources_path="$3"
  local repo_url="$4"

  if [[ ! -f $keyring_path ]]; then
    curl -fsSL "$keyring_url" | gpg --dearmor 2>/dev/null | sudo tee "$keyring_path" > /dev/null
  else
    remote_hash=$(curl -fsSL "$keyring_url" | gpg --dearmor 2>/dev/null | sha256sum | cut -d' ' -f1)

    if [[ -z $remote_hash ]]; then
      echo "Warning: failed to fetch remote keyring for $keyring_path, skipping update."
    else
      local_hash=$(sha256sum "$keyring_path" | cut -d' ' -f1)

      if [[ $remote_hash != $local_hash ]]; then
        echo "Keyring updated: $keyring_path"
        curl -fsSL "$keyring_url" | gpg --dearmor 2>/dev/null | sudo tee "$keyring_path" > /dev/null
      else
        _keyrings_up_to_date=$((_keyrings_up_to_date + 1))
      fi
    fi
  fi

  if [[ ! -f $sources_path ]]; then
    echo "Sources list missing, installing: $sources_path"
    echo "deb [arch=$(dpkg --print-architecture) signed-by=$keyring_path] $repo_url $suite main" \
      | sudo tee "$sources_path" > /dev/null
  fi
}

echo -e "\e[32m\nUpdate Omakasui signing keys\e[0m"

_keyrings_up_to_date=0

_ensure_keyring \
  "https://keyrings.omakasui.org/omakasui-core.gpg.key" \
  "/usr/share/keyrings/omakasui-core.gpg" \
  "/etc/apt/sources.list.d/omakasui-core.list" \
  "https://core.omakasui.org"

_ensure_keyring \
  "https://keyrings.omakasui.org/omakasui-packages.gpg.key" \
  "/usr/share/keyrings/omakasui-packages.gpg" \
  "/etc/apt/sources.list.d/omakasui.list" \
  "https://packages.omakasui.org"

if [[ $_keyrings_up_to_date -gt 0 ]]; then
  echo "Keyrings up to date, skipping."
fi