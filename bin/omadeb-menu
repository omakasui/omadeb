  case $(menu "Keybindings" "’ä£   Add\n’ä£   Remove") in
  *Add*) present_terminal omadeb-keybinding-add ;;
  *Remove*) present_terminal omadeb-keybinding-remove ;;
  *) show_setup_menu ;;
  esac
}

