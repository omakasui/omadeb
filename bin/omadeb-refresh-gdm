#!/bin/bash

OMADEB_PATH="$HOME/.local/share/omadeb"

sudo mkdir -p /usr/share/pixmaps/omadeb
sudo cp "$OMADEB_PATH/default/gdm/logo.png" /usr/share/pixmaps/omadeb/gdm-logo.png
sudo cp "$OMADEB_PATH/default/gdm/background.png" /usr/share/pixmaps/omadeb/gdm-background.png
sudo cp "$OMADEB_PATH/default/gdm/greeter.dconf-defaults" /etc/gdm3/greeter.dconf-defaults
sudo dconf update