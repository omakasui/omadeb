  case $(menu "Folders" "󰮝  Add\n󰮞  Remove" "--width 250 --height 130") in
  *Add*) present_terminal omadeb-app-folder-add ;;
  *Remove*) present_terminal omadeb-app-folder-remove ;;
  *) show_setup_menu ;;
  esac
}

