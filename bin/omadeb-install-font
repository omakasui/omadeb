#!/bin/bash

# Install one of the supported fonts. Usually called via Install > Fonts > * in the Omadeb Menu.

if [[ -z $1 ]]; then
  echo "Usage: omadeb-install-font <font>" >&2
  exit 1
fi

mkdir -p ~/.local/share/fonts

case "$1" in
jetbrains-mono)
  omadeb-pkg-add font-jetbrains-mono
  ;;
iafonts)
  omadeb-pkg-add font-ia-writer-mono
  ;;
cascadia-mono)
  omadeb-pkg-add font-cascadia-mono-nf
  ;;
mscore)
  omadeb-pkg-add ttf-mscorefonts-installer
  ;;
*)
  echo "Usage: omadeb-install-font <font>" >&2
  exit 1
  ;;
esac

fc-cache